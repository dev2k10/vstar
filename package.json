{
    "name": "vstar-browser",
    "version": "1.0.0",
    "description": "VStar Browser – a lightweight Electron-based browser",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "author": "VStar Team",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.vstar.browser",
        "productName": "VStar Browser",
        "files": [
            "main.js",
            "preload.js",
            "ui/**"
        ],
        "win": {
            "target": "nsis",
            "icon": "ui/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "ui/icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "ui/icon.png"
        }
    }
}
